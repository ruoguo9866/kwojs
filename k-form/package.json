{
  "name": "@ruoguo/k-form",
  "version": "1.0.0",
  "description": "基于 antd-mobile Form 的可配置表单：表单项可从接口获取配置，自动生成表单",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./schema": "./schema.js",
    "./demo": "./demo.jsx"
  },
  "scripts": {
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest",
    "demo": "cd demo && vite --open"
  },
  "files": [
    "index.js",
    "ConfigForm.js",
    "schema.js",
    "demo.jsx",
    "README.md"
  ],
  "keywords": [
